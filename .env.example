# ─────────────────────────────────────────────────────────────────────────────
# arcadii (hexii) backend environment. Copy to .env / .env.local and fill in.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── TURN / coturn (arcade-turn on Fly) ──────────────────────────────────────
# 64-char hex shared secret; must match the coturn static-auth-secret.
TURN_SHARED_SECRET=
TURN_HOST=arcade-turn.fly.dev
# Optional SECOND TURN server on a DIFFERENT public IP (arcade-turn-b). Enables
# the relay fallback for same-WiFi peers: a different-IP cross-pair dodges the
# WebRTC self-loop pruning that a single server hits. Same TURN_SHARED_SECRET
# authenticates on both. Leave unset to run single-server.
TURN_HOST_B=arcade-turn-b.fly.dev
# Bearer token the coturn usage-reporter uses to POST /api/turn/usage.
TURN_USAGE_TOKEN=

# ── Session-token auth (signalling hardening) ───────────────────────────────
# HMAC secret for the short-lived session JWTs minted at /api/auth/token.
# REQUIRED in production (the app refuses to mint tokens without it).
SESSION_TOKEN_SECRET=
# When "true", signalling endpoints REQUIRE a session token and reject a raw
# API key. Leave off (unset/false) during the client rollout, flip on once
# every game ships the token exchange.
ENFORCE_SESSION_TOKENS=

# ── Attestation providers ───────────────────────────────────────────────────
# Cloudflare Turnstile (web platform). Secret key; the public site key lives in
# the web games' env. If unset: allowed in dev, REJECTED in production.
TURNSTILE_SECRET=
# Steam auth-ticket verification (steam platform). Publisher Web API key + the
# game's Steam App ID (bouncy-blobs = 4485010). If unset: allowed in dev,
# REJECTED in production.
STEAM_WEBAPI_PUBLISHER_KEY=
STEAM_APP_ID=

# ── Usage-spike alerts (cron) ───────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@sterlinglong.me
USAGE_ALERT_TO=ster@sterlinglong.me
USAGE_ALERT_ROOMS_PER_HOUR=500
USAGE_ALERT_TURN_GB_PER_DAY=10
# Optional shared secret Vercel cron presents as `Authorization: Bearer <...>`.
CRON_SECRET=

# ── Optional: Upstash Redis (hard cross-instance rate limiting) ─────────────
# If set, swap lib/api/quota.ts's in-memory limiter for an Upstash-backed one.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Misc ────────────────────────────────────────────────────────────────────
ADMIN_API_TOKEN=
