{
  "name": "temp-hexii",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "env:push": "scripts/sync-env-to-vercel.sh production .env",
    "env:push:preview": "scripts/sync-env-to-vercel.sh preview .env",
    "env:push:all": "scripts/sync-env-to-vercel.sh all .env",
    "env:pull": "vercel env pull .env",
    "generate:soundtrack": "tsx scripts/generate-soundtrack.ts",
    "generate:sfx": "tsx scripts/generate-sfx.ts",
    "generate:mesh": "tsx scripts/generate-mesh.ts",
    "upload:post": "tsx scripts/upload-post.ts",
    "gyrii:generate": "spacetime generate --lang typescript --out-dir games/gyrii/generated --project-path games/gyrii/spacetimedb",
    "gyrii:spacetime:build": "cd games/gyrii/spacetimedb && spacetime build",
    "gyrii:spacetime:clean": "cd games/gyrii/spacetimedb && rm -rf ~/.local/share/spacetime/data && (pkill -f 'spacetime.*start' || pkill -f 'spacetime.*dev' || true) && echo 'Cleaned SpacetimeDB build artifacts, database, and stopped processes'",
    "gyrii:spacetime:start": "cd games/gyrii/spacetimedb && spacetime start -l 0.0.0.0:3001",
    "gyrii:spacetime:dev": "cd games/gyrii && spacetime dev --server http://127.0.0.1:3001 gyrii --yes --module-project-path spacetimedb",
    "gyrii:spacetime:run": "(npm run gyrii:spacetime:start &) && sleep 5 && npm run gyrii:spacetime:dev",
    "gyrii:spacetime:logs": "spacetime logs gyrii --server http://127.0.0.1:3001",
    "gyrii:spacetime:publish": "cd games/gyrii && spacetime publish gyrii --project-path spacetimedb -s maincloud",
    "gyrii:spacetime:publish:break": "cd games/gyrii && spacetime publish --break-clients gyrii --project-path spacetimedb -s maincloud",
    "gyrii:spacetime:publish:reset": "cd games/gyrii && spacetime publish --delete-data gyrii --project-path spacetimedb -s maincloud",
    "gyrii:spacetime:publish:local": "cd games/gyrii && spacetime publish gyrii --project-path spacetimedb -s http://127.0.0.1:3001",
    "gyrii:server:build": "cargo build --manifest-path games/gyrii/server/Cargo.toml",
    "gyrii:server:run": "GYRII_ENV_FILE=.env.local cargo run --manifest-path games/gyrii/server/Cargo.toml",
    "gyrii:server:run:prod": "GYRII_ENV_FILE=.env cargo run --manifest-path games/gyrii/server/Cargo.toml",
    "gyrii:proto:generate": "cd games/gyrii && npx buf generate"
  },
  "dependencies": {
    "@babylonjs/core": "^7.x",
    "@babylonjs/loaders": "^7.x",
    "@bufbuild/protobuf": "^2.2.0",
    "@dimforge/rapier3d": "^0.12.0",
    "@mux/mux-node": "^14.0.1",
    "@mux/mux-player-react": "^3.13.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.3.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.1",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "next": "^15.1.6",
    "phaser": "^3.90.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.12.2",
    "spacetimedb": "^1.12.0",
    "stripe": "^22.1.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.65.0",
    "@bufbuild/protoc-gen-es": "^2.2.0",
    "@elevenlabs/elevenlabs-js": "^2.32.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.1.6",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "upload-post": "^1.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
